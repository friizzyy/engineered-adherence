{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/us", "destination": "/us/index.html" },
    { "source": "/qa", "destination": "/qa/index.html" }
  ],
  "cleanUrls": true,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 15
    }
  }
}
